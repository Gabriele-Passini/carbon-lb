{
  "title": "Carbon-Aware Load Balancer",
  "uid": "carbonlb-main",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Healthy Nodes",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{ "expr": "carbonlb_healthy_nodes", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "orientation": "auto" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "red", "value": 0 },
        { "color": "yellow", "value": 2 },
        { "color": "green", "value": 3 }
      ]}}}
    },
    {
      "id": 2,
      "title": "Requests per Second",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 8 },
      "targets": [
        { "expr": "rate(carbonlb_requests_total{algorithm=\"carbon_aware\"}[1m])", "legendFormat": "carbon_aware", "refId": "A" },
        { "expr": "rate(carbonlb_requests_total{algorithm=\"round_robin\"}[1m])", "legendFormat": "round_robin", "refId": "B" }
      ]
    },
    {
      "id": 3,
      "title": "Total Estimated CO₂ Emitted (gCO₂)",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 8 },
      "targets": [
        { "expr": "carbonlb_total_carbon_emitted_gco2{algorithm=\"carbon_aware\"}", "legendFormat": "carbon_aware", "refId": "A" },
        { "expr": "carbonlb_total_carbon_emitted_gco2{algorithm=\"round_robin\"}", "legendFormat": "round_robin", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }}}
    },
    {
      "id": 4,
      "title": "Carbon Intensity per Node (gCO₂/kWh)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "carbonlb_node_carbon_intensity_gco2_kwh", "legendFormat": "{{node_id}} ({{region}})", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Energy Consumption per Node (W)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "carbonlb_node_energy_watts", "legendFormat": "{{node_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "watt" }}
    },
    {
      "id": 6,
      "title": "Node Carbon Score (lower = greener)",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "carbonlb_node_carbon_score", "legendFormat": "{{node_id}}", "refId": "A", "instant": true }
      ],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }},
      "fieldConfig": { "defaults": {
        "min": 0, "max": 1,
        "thresholds": { "steps": [
          { "color": "green", "value": 0 },
          { "color": "yellow", "value": 0.4 },
          { "color": "red", "value": 0.7 }
        ]}
      }}
    },
    {
      "id": 7,
      "title": "Request Latency p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(carbonlb_request_duration_seconds_bucket[1m]))", "legendFormat": "p99 {{algorithm}}", "refId": "A" },
        { "expr": "histogram_quantile(0.50, rate(carbonlb_request_duration_seconds_bucket[1m]))", "legendFormat": "p50 {{algorithm}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }}
    },
    {
      "id": 8,
      "title": "Active Connections per Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        { "expr": "carbonlb_node_active_connections", "legendFormat": "{{node_id}}", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "title": "CPU Usage per Node (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        { "expr": "carbonlb_node_cpu_usage_percent", "legendFormat": "{{node_id}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }}
    }
  ]
}
